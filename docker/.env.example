# ═══════════════════════════════════════════════
# KlipperOS-AI Docker Environment
# Bu dosyayi .env olarak kopyalayip duzenlein:
#   cp docker/.env.example .env
# ═══════════════════════════════════════════════

# Moonraker API adresi (host'ta calisan Moonraker)
# Docker icinden host'a erisim: host.docker.internal
KOS_MOONRAKER_URL=http://host.docker.internal:7125

# JWT secret (bos birakirsaniz otomatik olusturulur)
KOS_JWT_SECRET=

# AI model dizini (host path)
KOS_MODELS_DIR=./ai-monitor/models
