# =============================================================================
# KlipperAI-OS — Deferred (Ertelenmiş) Paket Listesi
# =============================================================================
# Bu paketler ISO'ya dahil edilmez. First-boot wizard tarafindan
# ag baglantisi kurulduktan sonra apt-get ile yuklenir.
#
# Bu dosya wizard tarafindan okunur ve install edilir.
# Her satir bir paket, # ile baslayan satirlar yorum.
# =============================================================================

# --- Temel Sistem (ek) ---
lsb-release
apt-transport-https
software-properties-common

# --- Python (tam) ---
python3-venv
python3-pip
python3-dev
python3-setuptools
python3-wheel

# --- Build Tools (Klipper firmware derleme) ---
git
build-essential
cmake
pkg-config

# --- ARM Cross-Compiler (MCU firmware) ---
gcc-arm-none-eabi
binutils-arm-none-eabi
libnewlib-arm-none-eabi

# --- Firmware Flash Araclari ---
stm32flash
dfu-util
avrdude

# --- Display / GTK (KlipperScreen icin) ---
xserver-xorg
xinit
x11-xserver-utils
python3-gi
python3-gi-cairo
gir1.2-gtk-3.0
gir1.2-vte-2.91
libopenjp2-7
libcairo2-dev
fonts-freefont-ttf
xinput
matchbox-keyboard

# --- Web Server ---
nginx

# --- Sistem Araclari ---
python3-psutil
zstd
usbutils
pciutils
v4l-utils
ffmpeg

# --- Klipper CANBUS ---
can-utils
